# ── Endee Vector Database ────────────────────────────────────────────────────
ENDEE_HOST=http://localhost:8080
ENDEE_AUTH_TOKEN=          # leave empty for unauthenticated mode
INDEX_NAME=devmind_code

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=40
CHUNK_OVERLAP=8
BATCH_SIZE=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5

# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY= 
LLM_MODEL=gemini-2.5-flash-lite
